    63	openapi: 3.0.3
    64	info:
    65	  title: CampusFlow API
    66	  description: |
    67	    CampusFlow 是校园任务管理系统。
    68	
    69	    **重要约束**：
    70	    - 任务标题最大 100 字符
    71	    - 任务 ID 是 UUID 格式
    72	    - 所有日期时间使用 ISO 8601 格式
    73	  version: 1.0.0
    74	
    75	servers:
