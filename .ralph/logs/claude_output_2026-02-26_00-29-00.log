{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_b3a52ebeb0de4e109b67c892","type":"tool_result","content":"     1→/*\n     2→ * 示例：参数化测试 - 使用 @ParameterizedTest 批量验证边界情况。\n     3→ * 运行方式：mvn -q -f chapters/week_06/starter_code/pom.xml test -Dtest=LibraryTrackerParameterizedTest\n     4→ * 预期输出：测试通过，每组参数生成一个独立的测试用例\n     5→ *\n     6→ * 关键概念：\n     7→ * - @ParameterizedTest: 标记参数化测试\n     8→ * - @ValueSource: 提供简单值列表\n     9→ * - @NullAndEmptySource: 专门提供 null 和空值\n    10→ * - @CsvSource: CSV 格式的表格数据\n    11→ * - @MethodSource: 引用方法提供参数（本例未展示）\n    12→ */\n    13→\n    14→import org.junit.jupiter.api.BeforeEach;\n    15→import org.junit.jupiter.params.ParameterizedTest;\n    16→import org.junit.jupiter.params.provider.CsvSource;\n    17→import org.junit.jupiter.params.provider.NullAndEmptySource;\n    18→import org.junit.jupiter.params.provider.ValueSource;\n    19→import static org.junit.jupiter.api.Assertions.*;\n    20→\n    21→/**\n    22→ * 图书类\n    23→ */\n    24→class Book {\n    25→    private String title;\n    26→    private String author;\n    27→    private String isbn;\n    28→\n    29→    public Book(String title, String author, String isbn) {\n    30→        this.title = title;\n    31→        this.author = author;\n    32→        this.isbn = isbn;\n    33→    }\n    34→\n    35→    public String getTitle() { return title; }\n    36→    public String getAuthor() { return author; }\n    37→    public String getIsbn() { return isbn; }\n    38→}\n    39→\n    40→/**\n    41→ * 借阅记录类\n    42→ */\n    43→class BorrowRecord {\n    44→    private String isbn;\n    45→    private String borrower;\n    46→\n    47→    public BorrowRecord(String isbn, String borrower) {\n    48→        this.isbn = isbn;\n    49→        this.borrower = borrower;\n    50→    }\n    51→\n    52→    public String getIsbn() { return isbn; }\n    53→    public String getBorrower() { return borrower; }\n    54→}\n    55→\n    56→/**\n    57→ * 图书追踪器\n    58→ */\n    59→class LibraryTracker {\n    60→    private java.util.HashMap<String, Book> booksByIsbn;\n    61→    private java.util.ArrayList<BorrowRecord> borrowRecords;\n    62→\n    63→    public LibraryTracker() {\n    64→        booksByIsbn = new java.util.HashMap<>();\n    65→        borrowRecords = new java.util.ArrayList<>();\n    66→    }\n    67→\n    68→    public void addBook(Book book) {\n    69→        if (book == null || book.getIsbn() == null) {\n    70→            throw new IllegalArgumentException(\"图书信息不完整\");\n    71→        }\n    72→        booksByIsbn.put(book.getIsbn(), book);\n    73→    }\n    74→\n    75→    public Book findBook(String isbn) {\n    76→        return booksByIsbn.get(isbn);\n    77→    }\n    78→\n    79→    public void borrowBook(String isbn, String borrower) {\n    80→        if (isbn == null || isbn.isEmpty()) {\n    81→            throw new IllegalArgumentException(\"ISBN 不能为空\");\n    82→        }\n    83→        if (borrower == null || borrower.isEmpty()) {\n    84→            throw new IllegalArgumentException(\"借阅人不能为空\");\n    85→        }\n    86→        if (!booksByIsbn.containsKey(isbn)) {\n    87→            throw new IllegalArgumentException(\"图书不存在：\" + isbn);\n    88→        }\n    89→        borrowRecords.add(new BorrowRecord(isbn, borrower));\n    90→    }\n    91→\n    92→    public boolean hasBorrowRecord(String isbn, String borrower) {\n    93→        for (BorrowRecord record : borrowRecords) {\n    94→            if (record.getIsbn().equals(isbn) && record.getBorrower().equals(borrower)) {\n    95→                return true;\n    96→            }\n    97→        }\n    98→        return false;\n    99→    }\n   100→}\n   101→\n   102→/**\n   103→ * 参数化测试类\n   104→ *\n   105→ * 反例（不使用参数化测试时的代码膨胀）：\n   106→ * ```java\n   107→ * @Test\n   108→ * void shouldRejectEmptyIsbn() { ... }\n   109→ *\n   110→ * @Test\n   111→ * void shouldRejectBlankIsbn() { ... }\n   112→ *\n   113→ * @Test\n   114→ * void shouldRejectNullIsbn() { ... }\n   115→ *\n   116→ * @Test\n   117→ * void shouldRejectInvalidIsbn() { ... }\n   118→ * // 重复的方法，几乎相同的代码\n   119→ * ```\n   120→ */\n   121→class LibraryTrackerParameterizedTest {\n   122→\n   123→    private LibraryTracker tracker;\n   124→\n   125→    @BeforeEach\n   126→    void setUp() {\n   127→        tracker = new LibraryTracker();\n   128→    }\n   129→\n   130→    /**\n   131→     * @ValueSource 用于提供简单的值列表（字符串、整数等）\n   132→     * 每个值会生成一个独立的测试用例\n   133→     */\n   134→    @ParameterizedTest\n   135→    @ValueSource(strings = {\"\", \"   \", \"invalid-isbn\", \"123\", \"ISBN@#$\"})\n   136→    void shouldRejectInvalidIsbn(String invalidIsbn) {\n   137→        tracker.addBook(new Book(\"书\", \"作者\", \"VALID-ISBN\"));\n   138→\n   139→        // 验证所有无效 ISBN 都应该抛出异常\n   140→        assertThrows(IllegalArgumentException.class, () -> {\n   141→            tracker.borrowBook(invalidIsbn, \"小北\");\n   142→        });\n   143→    }\n   144→\n   145→    /**\n   146→     * @NullAndEmptySource 专门用于测试 null 和空字符串\n   147→     * 这是边界测试的必备组合\n   148→     */\n   149→    @ParameterizedTest\n   150→    @NullAndEmptySource\n   151→    void shouldRejectNullOrEmptyIsbn(String invalidIsbn) {\n   152→        tracker.addBook(new Book(\"书\", \"作者\", \"VALID-ISBN\"));\n   153→\n   154→        assertThrows(IllegalArgumentException.class, () -> {\n   155→            tracker.borrowBook(invalidIsbn, \"小北\");\n   156→        });\n   157→    }\n   158→\n   159→    /**\n   160→     * @CsvSource 用于表格形式的数据\n   161→     * 格式：\"值1, 值2, 期望值\"\n   162→     * 适合测试输入-输出映射关系\n   163→     */\n   164→    @ParameterizedTest\n   165→    @CsvSource({\n   166→        \"ISBN-1, 小北, true\",    // 正常借阅\n   167→        \"ISBN-2, 小北, false\",   // 书不存在\n   168→        \"ISBN-1, 阿码, false\"    // 书存在但借给其他人了\n   169→    })\n   170→    void shouldCheckBorrowStatus(String isbn, String borrower, boolean expectedExists) {\n   171→        // 准备数据\n   172→        tracker.addBook(new Book(\"书1\", \"作者\", \"ISBN-1\"));\n   173→        tracker.borrowBook(\"ISBN-1\", \"小北\");\n   174→\n   175→        // 验证\n   176→        boolean exists = tracker.hasBorrowRecord(isbn, borrower);\n   177→        assertEquals(expectedExists, exists,\n   178→            String.format(\"查询 ISBN=%s, borrower=%s 应该返回 %b\", isbn, borrower, expectedExists));\n   179→    }\n   180→\n   181→    /**\n   182→     * 更复杂的 CSV 场景：多字段验证\n   183→     */\n   184→    @ParameterizedTest\n   185→    @CsvSource({\n   186→        \"ISBN-001, 书1, 作者A\",\n   187→        \"ISBN-002, 书2, 作者B\",\n   188→        \"ISBN-003, 书3, 作者C\"\n   189→    })\n   190→    void shouldAddAndRetrieveMultipleBooks(String isbn, String title, String author) {\n   191→        Book book = new Book(title, author, isbn);\n   192→        tracker.addBook(book);\n   193→\n   194→        Book found = tracker.findBook(isbn);\n   195→        assertNotNull(found);\n   196→        assertEquals(title, found.getTitle());\n   197→        assertEquals(author, found.getAuthor());\n   198→    }\n   199→\n   200→    /**\n   201→     * 可以组合多个数据源\n   202→     * 注意：@NullAndEmptySource 已包含 null 和 \"\"，所以 @ValueSource 只需补充其他值\n   203→     */\n   204→    @ParameterizedTest\n   205→    @NullAndEmptySource\n   206→    @ValueSource(strings = {\"   \"})\n   207→    void shouldRejectAllInvalidBorrowers(String invalidBorrower) {\n   208→        tracker.addBook(new Book(\"书\", \"作者\", \"ISBN-1\"));\n   209→\n   210→        assertThrows(IllegalArgumentException.class, () -> {\n   211→            tracker.borrowBook(\"ISBN-1\", invalidBorrower);\n   212→        });\n   213→    }\n   214→\n   215→    /**\n   216→     * 使用 name 属性自定义测试报告中的显示名称\n   217→     */\n   218→    @ParameterizedTest(name = \"[{index}] ISBN={0}, borrower={1} 应该返回 {2}\")\n   219→    @CsvSource({\n   220→        \"ISBN-1, 小北, true\",\n   221→        \"ISBN-2, 小北, false\"\n   222→    })\n   223→    void shouldCheckBorrowStatusWithCustomName(String isbn, String borrower, boolean expected) {\n   224→        tracker.addBook(new Book(\"书1\", \"作者\", \"ISBN-1\"));\n   225→        tracker.borrowBook(\"ISBN-1\", \"小北\");\n   226→\n   227→        assertEquals(expected, tracker.hasBorrowRecord(isbn, borrower));\n   228→    }\n   229→}\n   230→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"71156586-c7e3-42b6-afb9-166ae181c2a1","uuid":"1415aa75-2910-45df-bae1-f0b6eb3504a5","tool_use_result":{"type":"text","file":{"filePath":"/home/ubuntu/java-software-engineering/chapters/week_06/examples/05_parameterized_test.java","content":"/*\n * 示例：参数化测试 - 使用 @ParameterizedTest 批量验证边界情况。\n * 运行方式：mvn -q -f chapters/week_06/starter_code/pom.xml test -Dtest=LibraryTrackerParameterizedTest\n * 预期输出：测试通过，每组参数生成一个独立的测试用例\n *\n * 关键概念：\n * - @ParameterizedTest: 标记参数化测试\n * - @ValueSource: 提供简单值列表\n * - @NullAndEmptySource: 专门提供 null 和空值\n * - @CsvSource: CSV 格式的表格数据\n * - @MethodSource: 引用方法提供参数（本例未展示）\n */\n\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.params.ParameterizedTest;\nimport org.junit.jupiter.params.provider.CsvSource;\nimport org.junit.jupiter.params.provider.NullAndEmptySource;\nimport org.junit.jupiter.params.provider.ValueSource;\nimport static org.junit.jupiter.api.Assertions.*;\n\n/**\n * 图书类\n */\nclass Book {\n    private String title;\n    private String author;\n    private String isbn;\n\n    public Book(String title, String author, String isbn) {\n        this.title = title;\n        this.author = author;\n        this.isbn = isbn;\n    }\n\n    public String getTitle() { return title; }\n    public String getAuthor() { return author; }\n    public String getIsbn() { return isbn; }\n}\n\n/**\n * 借阅记录类\n */\nclass BorrowRecord {\n    private String isbn;\n    private String borrower;\n\n    public BorrowRecord(String isbn, String borrower) {\n        this.isbn = isbn;\n        this.borrower = borrower;\n    }\n\n    public String getIsbn() { return isbn; }\n    public String getBorrower() { return borrower; }\n}\n\n/**\n * 图书追踪器\n */\nclass LibraryTracker {\n    private java.util.HashMap<String, Book> booksByIsbn;\n    private java.util.ArrayList<BorrowRecord> borrowRecords;\n\n    public LibraryTracker() {\n        booksByIsbn = new java.util.HashMap<>();\n        borrowRecords = new java.util.ArrayList<>();\n    }\n\n    public void addBook(Book book) {\n        if (book == null || book.getIsbn() == null) {\n            throw new IllegalArgumentException(\"图书信息不完整\");\n        }\n        booksByIsbn.put(book.getIsbn(), book);\n    }\n\n    public Book findBook(String isbn) {\n        return booksByIsbn.get(isbn);\n    }\n\n    public void borrowBook(String isbn, String borrower) {\n        if (isbn == null || isbn.isEmpty()) {\n            throw new IllegalArgumentException(\"ISBN 不能为空\");\n        }\n        if (borrower == null || borrower.isEmpty()) {\n            throw new IllegalArgumentException(\"借阅人不能为空\");\n        }\n        if (!booksByIsbn.containsKey(isbn)) {\n            throw new IllegalArgumentException(\"图书不存在：\" + isbn);\n        }\n        borrowRecords.add(new BorrowRecord(isbn, borrower));\n    }\n\n    public boolean hasBorrowRecord(String isbn, String borrower) {\n        for (BorrowRecord record : borrowRecords) {\n            if (record.getIsbn().equals(isbn) && record.getBorrower().equals(borrower)) {\n                return true;\n            }\n        }\n        return false;\n    }\n}\n\n/**\n * 参数化测试类\n *\n * 反例（不使用参数化测试时的代码膨胀）：\n * ```java\n * @Test\n * void shouldRejectEmptyIsbn() { ... }\n *\n * @Test\n * void shouldRejectBlankIsbn() { ... }\n *\n * @Test\n * void shouldRejectNullIsbn() { ... }\n *\n * @Test\n * void shouldRejectInvalidIsbn() { ... }\n * // 重复的方法，几乎相同的代码\n * ```\n */\nclass LibraryTrackerParameterizedTest {\n\n    private LibraryTracker tracker;\n\n    @BeforeEach\n    void setUp() {\n        tracker = new LibraryTracker();\n    }\n\n    /**\n     * @ValueSource 用于提供简单的值列表（字符串、整数等）\n     * 每个值会生成一个独立的测试用例\n     */\n    @ParameterizedTest\n    @ValueSource(strings = {\"\", \"   \", \"invalid-isbn\", \"123\", \"ISBN@#$\"})\n    void shouldRejectInvalidIsbn(String invalidIsbn) {\n        tracker.addBook(new Book(\"书\", \"作者\", \"VALID-ISBN\"));\n\n        // 验证所有无效 ISBN 都应该抛出异常\n        assertThrows(IllegalArgumentException.class, () -> {\n            tracker.borrowBook(invalidIsbn, \"小北\");\n        });\n    }\n\n    /**\n     * @NullAndEmptySource 专门用于测试 null 和空字符串\n     * 这是边界测试的必备组合\n     */\n    @ParameterizedTest\n    @NullAndEmptySource\n    void shouldRejectNullOrEmptyIsbn(String invalidIsbn) {\n        tracker.addBook(new Book(\"书\", \"作者\", \"VALID-ISBN\"));\n\n        assertThrows(IllegalArgumentException.class, () -> {\n            tracker.borrowBook(invalidIsbn, \"小北\");\n        });\n    }\n\n    /**\n     * @CsvSource 用于表格形式的数据\n     * 格式：\"值1, 值2, 期望值\"\n     * 适合测试输入-输出映射关系\n     */\n    @ParameterizedTest\n    @CsvSource({\n        \"ISBN-1, 小北, true\",    // 正常借阅\n        \"ISBN-2, 小北, false\",   // 书不存在\n        \"ISBN-1, 阿码, false\"    // 书存在但借给其他人了\n    })\n    void shouldCheckBorrowStatus(String isbn, String borrower, boolean expectedExists) {\n        // 准备数据\n        tracker.addBook(new Book(\"书1\", \"作者\", \"ISBN-1\"));\n        tracker.borrowBook(\"ISBN-1\", \"小北\");\n\n        // 验证\n        boolean exists = tracker.hasBorrowRecord(isbn, borrower);\n        assertEquals(expectedExists, exists,\n            String.format(\"查询 ISBN=%s, borrower=%s 应该返回 %b\", isbn, borrower, expectedExists));\n    }\n\n    /**\n     * 更复杂的 CSV 场景：多字段验证\n     */\n    @ParameterizedTest\n    @CsvSource({\n        \"ISBN-001, 书1, 作者A\",\n        \"ISBN-002, 书2, 作者B\",\n        \"ISBN-003, 书3, 作者C\"\n    })\n    void shouldAddAndRetrieveMultipleBooks(String isbn, String title, String author) {\n        Book book = new Book(title, author, isbn);\n        tracker.addBook(book);\n\n        Book found = tracker.findBook(isbn);\n        assertNotNull(found);\n        assertEquals(title, found.getTitle());\n        assertEquals(author, found.getAuthor());\n    }\n\n    /**\n     * 可以组合多个数据源\n     * 注意：@NullAndEmptySource 已包含 null 和 \"\"，所以 @ValueSource 只需补充其他值\n     */\n    @ParameterizedTest\n    @NullAndEmptySource\n    @ValueSource(strings = {\"   \"})\n    void shouldRejectAllInvalidBorrowers(String invalidBorrower) {\n        tracker.addBook(new Book(\"书\", \"作者\", \"ISBN-1\"));\n\n        assertThrows(IllegalArgumentException.class, () -> {\n            tracker.borrowBook(\"ISBN-1\", invalidBorrower);\n        });\n    }\n\n    /**\n     * 使用 name 属性自定义测试报告中的显示名称\n     */\n    @ParameterizedTest(name = \"[{index}] ISBN={0}, borrower={1} 应该返回 {2}\")\n    @CsvSource({\n        \"ISBN-1, 小北, true\",\n        \"ISBN-2, 小北, false\"\n    })\n    void shouldCheckBorrowStatusWithCustomName(String isbn, String borrower, boolean expected) {\n        tracker.addBook(new Book(\"书1\", \"作者\", \"ISBN-1\"));\n        tracker.borrowBook(\"ISBN-1\", \"小北\");\n\n        assertEquals(expected, tracker.hasBorrowRecord(isbn, borrower));\n    }\n}\n","numLines":230,"startLine":1,"totalLines":230}}}
